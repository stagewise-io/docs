{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "stagewise",
  "colors": {
    "primary": "#275BFF",
    "light": "#6698FF",
    "dark": "#081ECB"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "best-practices"
            ]
          },
          {
            "group": "Agent configuration",
            "pages": [
              "agent/models-and-providers",
              "agent/byok-setup",
              "agent/custom-providers",
              "agent/custom-models",
              "agent/skills-and-context",
              "agent/plugins"
            ]
          },
          {
            "group": "Browsing",
            "pages": [
              "browsing/general-settings",
              "browsing/history-and-downloads",
              "browsing/permissions",
              "browsing/clear-data"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/diff-review",
              "features/dom-context-selector",
              "features/keyboard-shortcuts"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "account/authentication",
              "account/about"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/stagewise/stagewise",
          "icon": "github"
        },
        {
          "anchor": "Discord",
          "href": "https://stagewise.io/socials/discord",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://stagewise.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://stagewise.io"
    }
  },
  "footer": {
    "socials": {
      "x": "https://stagewise.io/socials/x",
      "github": "https://github.com/stagewise/stagewise",
      "linkedin": "https://stagewise.io/socials/linkedin",
      "discord": "https://stagewise.io/socials/discord"
    }
  }
}
